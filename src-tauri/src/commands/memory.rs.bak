//! Memory Management Commands

use serde::{Deserialize, Serialize};
use std::fs;
use std::path::PathBuf;
use chrono::{Local, Datelike};

fn get_data_dir() -> PathBuf {
    dirs::data_local_dir()
        .unwrap_or_else(|| PathBuf::from("."))
        .join("BongoCat")
}

fn get_memory_dir() -> PathBuf {
    get_data_dir().join("memory")
}

fn get_chat_dir() -> PathBuf {
    get_memory_dir().join("chat")
}

fn get_weekly_dir() -> PathBuf {
    get_memory_dir().join("weekly")
}

fn get_monthly_dir() -> PathBuf {
    get_memory_dir().join("monthly")
}

fn ensure_dirs() -> Result<(), String> {
    fs::create_dir_all(get_chat_dir()).map_err(|e| e.to_string())?;
    fs::create_dir_all(get_weekly_dir()).map_err(|e| e.to_string())?;
    fs::create_dir_all(get_monthly_dir()).map_err(|e| e.to_string())?;
    Ok(())
}

#[derive(Debug, Serialize, Deserialize, Clone)]
pub struct ChatMessage {
    pub id: String,
    pub role: String,
    pub content: String,
    pub timestamp: i64,
}

#[derive(Debug, Serialize, Deserialize)]
pub struct DayChat {
    pub date: String,
    pub messages: Vec<ChatMessage>,
}

#[derive(Debug, Serialize, Deserialize)]
pub struct WeeklySummary {
    pub week: String,
    pub date_range: String,
    pub keywords: Vec<String>,
    pub emotion_arc: Vec<String>,
    pub summary: String,
    pub important_events: Vec<String>,
    pub chat_count: i32,
}

#[derive(Debug, Serialize, Deserialize)]
pub struct MonthlySummary {
    pub month: String,
    pub emotion_distribution: std::collections::HashMap<String, i32>,
    pub topics: Vec<String>,
    pub relationship_growth: String,
    pub milestones: Vec<String>,
}

fn get_today() -> String {
    Local::now().format("%Y-%m-%d").to_string()
}

fn get_current_week() -> String {
    let now = Local::now();
    let week = now.format("%Y-W%U").to_string();
    week
}

fn get_current_month() -> String {
    Local::now().format("%Y-%m").to_string()
}

/// Save chat message to today's file
#[tauri::command]
pub fn save_chat_message(message: ChatMessage) -> Result<(), String> {
    ensure_dirs()?;
    
    let today = get_today();
    let file_path = get_chat_dir().join(format!("{}.json", today));
    
    let mut day_chat = if file_path.exists() {
        let content = fs::read_to_string(&file_path).map_err(|e| e.to_string())?;
        serde_json::from_str::<DayChat>(&content).unwrap_or(DayChat {
            date: today.clone(),
            messages: vec![],
        })
    } else {
        DayChat {
            date: today.clone(),
            messages: vec![],
        }
    };
    
    day_chat.messages.push(message);
    
    let content = serde_json::to_string_pretty(&day_chat).map_err(|e| e.to_string())?;
    fs::write(&file_path, content).map_err(|e| e.to_string())?;
    
    Ok(())
}

/// Get today's chat messages
#[tauri::command]
pub fn get_today_chat() -> Result<DayChat, String> {
    let today = get_today();
    let file_path = get_chat_dir().join(format!("{}.json", today));
    
    if !file_path.exists() {
        return Ok(DayChat {
            date: today,
            messages: vec![],
        });
    }
    
    let content = fs::read_to_string(&file_path).map_err(|e| e.to_string())?;
    serde_json::from_str(&content).map_err(|e| e.to_string())
}

/// Get chat messages by date
#[tauri::command]
pub fn get_chat_by_date(date: String) -> Result<DayChat, String> {
    let file_path = get_chat_dir().join(format!("{}.json", date));
    
    if !file_path.exists() {
        return Ok(DayChat {
            date,
            messages: vec![],
        });
    }
    
    let content = fs::read_to_string(&file_path).map_err(|e| e.to_string())?;
    serde_json::from_str(&content).map_err(|e| e.to_string())
}

/// Get chat dates (list of available dates)
#[tauri::command]
pub fn get_chat_dates() -> Result<Vec<String>, String> {
    let chat_dir = get_chat_dir();
    
    if !chat_dir.exists() {
        return Ok(vec![]);
    }
    
    let mut dates: Vec<String> = fs::read_dir(chat_dir)
        .map_err(|e| e.to_string())?
        .filter_map(|entry| {
            let name = entry.ok()?.file_name().to_str()?.to_string();
            if name.ends_with(".json") {
                Some(name.trim_end_matches(".json").to_string())
            } else {
                None
            }
        })
        .collect();
    
    dates.sort_by(|a, b| b.cmp(a)); // Sort descending (newest first)
    Ok(dates)
}

/// Save weekly summary
#[tauri::command]
pub fn save_weekly_summary(summary: WeeklySummary) -> Result<(), String> {
    ensure_dirs()?;
    
    let file_path = get_weekly_dir().join(format!("{}.json", summary.week));
    let content = serde_json::to_string_pretty(&summary).map_err(|e| e.to_string())?;
    fs::write(&file_path, content).map_err(|e| e.to_string())?;
    
    Ok(())
}

/// Get weekly summaries
#[tauri::command]
pub fn get_weekly_summaries() -> Result<Vec<WeeklySummary>, String> {
    let weekly_dir = get_weekly_dir();
    
    if !weekly_dir.exists() {
        return Ok(vec![]);
    }
    
    let mut summaries: Vec<WeeklySummary> = fs::read_dir(weekly_dir)
        .map_err(|e| e.to_string())?
        .filter_map(|entry| {
            let path = entry.ok()?.path();
            if path.extension()?.to_str()? == "json" {
                let content = fs::read_to_string(&path).ok()?;
                serde_json::from_str::<WeeklySummary>(&content).ok()
            } else {
                None
            }
        })
        .collect();
    
    summaries.sort_by(|a, b| b.week.cmp(&a.week));
    Ok(summaries)
}

