/// Get all chats for export
#[tauri::command]
pub fn export_all_chats() -> Result<String, String> {
    let chat_dir = get_chat_dir();
    
    if !chat_dir.exists() {
        return Ok("{}".to_string());
    }
    
    let mut all_chats: std::collections::HashMap<String, DayChat> = std::collections::HashMap::new();
    
    for entry in fs::read_dir(chat_dir).map_err(|e| e.to_string())? {
        let path = entry.map_err(|e| e.to_string())?.path();
        if path.extension().and_then(|s| s.to_str()) == Some("json") {
            let content = fs::read_to_string(&path).map_err(|e| e.to_string())?;
            if let Ok(day_chat) = serde_json::from_str::<DayChat>(&content) {
                all_chats.insert(day_chat.date.clone(), day_chat);
            }
        }
    }
    
    serde_json::to_string_pretty(&all_chats).map_err(|e| e.to_string())
}

/// Export all chats as Markdown
#[tauri::command]
pub fn export_chats_markdown() -> Result<String, String> {
    let chat_dir = get_chat_dir();
    
    if !chat_dir.exists() {
        return Ok("# 对话记录\n\n暂无对话".to_string());
    }
    
    let mut dates: Vec<String> = fs::read_dir(&chat_dir)
        .map_err(|e| e.to_string())?
        .filter_map(|entry| {
            let name = entry.ok()?.file_name().to_str()?.to_string();
            if name.ends_with(".json") {
                Some(name.trim_end_matches(".json").to_string())
            } else {
                None
            }
        })
        .collect();
    
    dates.sort_by(|a, b| b.cmp(a));
    
    let mut md = String::from("# 对话记录\n\n");
    
    for date in dates.iter().take(30) { // Last 30 days
        let file_path = chat_dir.join(format!("{}.json", date));
        let content = fs::read_to_string(&file_path).map_err(|e| e.to_string())?;
        let day_chat: DayChat = serde_json::from_str(&content).map_err(|e| e.to_string())?;
        
        if day_chat.messages.is_empty() {
            continue;
        }
        
        md.push_str(&format!("## {}\n\n", date));
        
        for msg in day_chat.messages {
            let role = if msg.role == "user" { "用户" } else { "Bongo Cat" };
            md.push_str(&format!("**{}**: {}\n\n", role, msg.content));
        }
    }
    
    Ok(md)
}

/// Clear all chat history
#[tauri::command]
pub fn clear_all_chats() -> Result<(), String> {
    let chat_dir = get_chat_dir();
    
    if chat_dir.exists() {
        fs::remove_dir_all(&chat_dir).map_err(|e| e.to_string())?;
    }
    
    ensure_dirs()?;
    Ok(())
}

/// Get memory storage info
#[tauri::command]
pub fn get_memory_info() -> Result<serde_json::Value, String> {
    let chat_dir = get_chat_dir();
    let weekly_dir = get_weekly_dir();
    let monthly_dir = get_monthly_dir();
    
    let chat_count = if chat_dir.exists() {
        fs::read_dir(chat_dir).map_err(|e| e.to_string())?.count()
    } else { 0 };
    
    let weekly_count = if weekly_dir.exists() {
        fs::read_dir(weekly_dir).map_err(|e| e.to_string())?.count()
    } else { 0 };
    
    let monthly_count = if monthly_dir.exists() {
        fs::read_dir(monthly_dir).map_err(|e| e.to_string())?.count()
    } else { 0 };
    
    Ok(serde_json::json!({
        "chat_days": chat_count,
        "weekly_summaries": weekly_count,
        "monthly_summaries": monthly_count,
        "storage_path": get_memory_dir().to_string_lossy()
    }))
}

// ============ Quarterly & Yearly Summaries ============

fn get_quarterly_dir() -> PathBuf {
    get_memory_dir().join("quarterly")
}

fn get_yearly_dir() -> PathBuf {
    get_memory_dir().join("yearly")
}

#[derive(Debug, Serialize, Deserialize)]
pub struct QuarterlySummary {
    pub quarter: String,
    pub date_range: String,
    pub keywords: Vec<String>,
    pub summary: String,
    pub important_events: Vec<String>,
    pub milestone: String,
    pub monthly_summaries_count: i32,
}

#[derive(Debug, Serialize, Deserialize)]
pub struct YearlySummary {
    pub year: String,
    pub keywords: Vec<String>,
    pub summary: String,
    pub relationship_growth: String,
    pub milestones: Vec<String>,
    pub memorable_moments: Vec<String>,
    pub quarterly_summaries_count: i32,
}

/// Save quarterly summary
#[tauri::command]
pub fn save_quarterly_summary(summary: QuarterlySummary) -> Result<(), String> {
    ensure_dirs()?;
    
    let file_path = get_quarterly_dir().join(format!("{}.json", summary.quarter));
    let content = serde_json::to_string_pretty(&summary).map_err(|e| e.to_string())?;
    fs::write(&file_path, content).map_err(|e| e.to_string())?;
    
    Ok(())
}

/// Get quarterly summaries
#[tauri::command]
pub fn get_quarterly_summaries() -> Result<Vec<QuarterlySummary>, String> {
    let quarterly_dir = get_quarterly_dir();
    
    if !quarterly_dir.exists() {
        return Ok(vec![]);
    }
    
    let mut summaries: Vec<QuarterlySummary> = fs::read_dir(quarterly_dir)
        .map_err(|e| e.to_string())?
        .filter_map(|entry| {
            let path = entry.ok()?.path();
            if path.extension().and_then(|s| s.to_str()) == Some("json") {
                let content = fs::read_to_string(&path).ok()?;
                serde_json::from_str::<QuarterlySummary>(&content).ok()
            } else {
                None
            }
        })
        .collect();
    
    summaries.sort_by(|a, b| b.quarter.cmp(&a.quarter));
    Ok(summaries)
}

/// Save yearly summary
#[tauri::command]
pub fn save_yearly_summary(summary: YearlySummary) -> Result<(), String> {
